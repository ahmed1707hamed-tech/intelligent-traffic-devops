pipeline {
    agent any

    stages {

        stage('Check Files') {
            steps {
                sh 'ls -la'
            }
        }

        stage('Build Dashboard Image') {
            steps {
                sh 'docker build -t traffic-dashboard ./services/traffic-dashboard'
            }
        }

        stage('Build Backend Image') {
            steps {
                sh 'docker build -t traffic-backend ./services/traffic-backend'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f kubernetes/'
            }
        }

    }
}
