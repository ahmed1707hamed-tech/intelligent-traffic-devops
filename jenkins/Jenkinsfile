pipeline {
    agent any

    stages {

        stage('Check Files') {
            steps {
                sh 'ls -la'
            }
        }

        stage('Check Services') {
            steps {
                sh 'ls -la services'
            }
        }

        stage('Build Dashboard Image') {
            steps {
                sh 'docker build -t traffic-dashboard ./services/traffic-dashboard'
            }
        }

        stage('Build Backend Image') {
            steps {
                sh '''
                if [ -d "./services/traffic-backend" ]; then
                    docker build -t traffic-backend ./services/traffic-backend
                else
                    echo "Backend folder not found, skipping build"
                fi
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f kubernetes/'
            }
        }

    }
}
